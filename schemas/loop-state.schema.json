{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gregoryhorn/hermes-loop-engineering/schemas/loop-state.schema.json",
  "title": "Hermes Loop State",
  "description": "Permissive public contract for durable Hermes loop state. Additional private/local fields are allowed.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "loop_name",
    "level",
    "status",
    "last_run_at",
    "last_status",
    "notification_policy",
    "kill_switch"
  ],
  "properties": {
    "loop_name": {"type": "string"},
    "level": {"type": "string"},
    "status": {"type": "string"},
    "version": {"type": "integer"},
    "job_id": {"type": "string"},
    "owner": {"type": "string"},
    "watched_scope": {"type": "object", "additionalProperties": true},
    "last_run_at": {"type": ["string", "null"], "format": "date-time"},
    "last_status": {"type": ["string", "null"]},
    "last_output_path": {"type": ["string", "null"]},
    "last_blocker_id": {"type": ["string", "null"]},
    "next_safe_action": {"type": ["string", "null"]},
    "findings": {"type": "array"},
    "decisions_needed": {"type": "array"},
    "attempt_counters": {"type": "object", "additionalProperties": true},
    "recent_runs": {"type": "array"},
    "notification_policy": {"type": "string"},
    "escalation_policy": {"type": "array"},
    "kill_switch": {"type": "string"},
    "pause_if": {"type": "array", "items": {"type": "string"}}
  }
}
